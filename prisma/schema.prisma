// This is your Prisma schema file for G•ONE

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  passwordHash   String
  role           UserRole @default(USER)
  telegramChatId String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  activities     Activity[]
  leads          Lead[]
  deals          Deal[]
  notifications  Notification[]
  activityLogs   ActivityLog[]

  @@map("gone_users")
}

enum UserRole {
  ADMIN
  USER
}

// ─────────────────────────────────────────
// CRM
// ─────────────────────────────────────────

model PipelineStage {
  id         String  @id @default(cuid())
  name       String
  orderIndex Int
  color      String  @default("#6B7280")

  deals      Deal[]

  @@map("gone_pipeline_stages")
}

model Lead {
  id            String   @id @default(cuid())
  name          String
  email         String?
  phone         String?
  company       String?
  notes         String?  @db.Text
  assignedUser  User     @relation(fields: [assignedUserId], references: [id])
  assignedUserId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  deals         Deal[]
  activities    Activity[]

  @@map("gone_leads")
}

model Deal {
  id              String        @id @default(cuid())
  title           String
  estimatedValue  Decimal?      @db.Decimal(12, 2)
  stage           PipelineStage @relation(fields: [stageId], references: [id])
  stageId         String
  lead            Lead          @relation(fields: [leadId], references: [id])
  leadId          String
  assignedUser    User          @relation(fields: [assignedUserId], references: [id])
  assignedUserId  String
  closedAt        DateTime?
  lostReason      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  activities      Activity[]
  project         Project?

  @@map("gone_deals")
}

// ─────────────────────────────────────────
// CONTROLE (Projetos e Tarefas)
// ─────────────────────────────────────────

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?   @db.Text
  deal        Deal?     @relation(fields: [dealId], references: [id])
  dealId      String?   @unique
  status      ProjectStatus @default(ACTIVE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  activities  Activity[]

  @@map("gone_projects")
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELED
}

// ─────────────────────────────────────────
// NÚCLEO — ACTIVITIES (fonte única de verdade)
// ─────────────────────────────────────────

model Activity {
  id             String         @id @default(cuid())
  type           ActivityType
  origin         ActivityOrigin @default(SYSTEM)
  entityType     String?        // "lead" | "deal" | "project"
  entityId       String?

  // Refs opcionais para as entidades
  lead           Lead?          @relation(fields: [leadId], references: [id])
  leadId         String?
  deal           Deal?          @relation(fields: [dealId], references: [id])
  dealId         String?
  project        Project?       @relation(fields: [projectId], references: [id])
  projectId      String?

  title          String
  description    String?        @db.Text
  dueAt          DateTime
  status         ActivityStatus @default(OPEN)
  priority       Priority       @default(MEDIUM)

  assignedUser   User           @relation(fields: [assignedUserId], references: [id])
  assignedUserId String

  snoozedUntil   DateTime?
  completedAt    DateTime?
  canceledAt     DateTime?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  notifications  Notification[]

  @@index([status, dueAt])
  @@index([assignedUserId, status])
  @@map("gone_activities")
}

enum ActivityType {
  FOLLOW_UP
  TASK
  MEETING
  DELIVERY
  REMINDER
}

enum ActivityOrigin {
  CRM
  CONTROLE
  SYSTEM
}

enum ActivityStatus {
  OPEN
  DONE
  SNOOZED
  CANCELED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

// ─────────────────────────────────────────
// NOTIFICAÇÕES
// ─────────────────────────────────────────

model Notification {
  id          String             @id @default(cuid())
  user        User               @relation(fields: [userId], references: [id])
  userId      String
  activity    Activity?          @relation(fields: [activityId], references: [id])
  activityId  String?
  type        NotificationType
  severity    NotificationSeverity @default(INFO)
  message     String             @db.Text
  isRead      Boolean            @default(false)
  sentAt      DateTime?
  ackAt       DateTime?
  createdAt   DateTime           @default(now())

  @@index([userId, isRead])
  @@map("gone_notifications")
}

enum NotificationType {
  T_MINUS_48H
  T_MINUS_24H
  T_MINUS_6H
  T_MINUS_2H
  T_MINUS_1H
  T_MINUS_30MIN
  OVERDUE
  OVERDUE_INSISTENT
  DAILY_DIGEST
}

enum NotificationSeverity {
  INFO
  WARNING
  CRITICAL
}

// ─────────────────────────────────────────
// AUDIT TRAIL
// ─────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  action    String
  details   String?  @db.Text
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("gone_activity_logs")
}
